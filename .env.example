# === Groq API ===
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# === Facebook / Instagram ===
FB_APP_SECRET=your_facebook_app_secret
FB_APP_ID=your_facebook_app_id
FB_REDIRECT_URI=https://your-domain.com/auth/callback
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_VERIFY_TOKEN=your_webhook_verify_token
IG_BUSINESS_ACCOUNT_ID=your_ig_account_id
FB_API_VERSION=v20.0

# === Legacy Facebook Tokens (backwards compat) ===
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=

# === Telegram (Staff Notifications) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_STAFF_CHAT_ID=your_staff_chat_id

# === Application ===
APP_SECRET_KEY=your_random_secret_key_change_this
DEBUG=false
DATABASE_URL=sqlite:///data/shop.db
LOG_LEVEL=INFO

# === Admin Dashboard Auth ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# === Rate Limiting ===
RATE_LIMIT_WEBHOOK=10/minute
RATE_LIMIT_ADMIN=30/minute
FAHD_COOLDOWN_AFTER_ESCALATION_MINUTES=30

# === Conversation Settings ===
CONVERSATION_TIMEOUT_MINUTES=30

# === Groq Retry ===
GROQ_MAX_RETRIES=3
GROQ_RETRY_DELAY=1.0

# === Caching ===
PRODUCT_CACHE_TTL_SECONDS=60

# === Session (new architecture) ===
SESSION_DB_PATH=data/sessions.db
SESSION_EXPIRY_HOURS=72
MAX_CONVERSATION_HISTORY=50

# === New Architecture Feature Flags ===
FEATURE_INTENT_CLASSIFIER=true
FEATURE_SQLITE_SESSION=true
FEATURE_ASYNC_METRICS=true
